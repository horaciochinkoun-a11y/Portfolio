rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Contact messages: anyone can submit (create), but only authenticated admins can read/write
    match /messages/{message} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // Projects: anyone can read, but only authenticated admins can write
    match /projects/{project} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Homepage content: anyone can read, but only authenticated admins can write
    match /content/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default deny rule for everything else
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
